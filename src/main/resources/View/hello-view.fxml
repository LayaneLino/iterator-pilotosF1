<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="600.0" prefWidth="660.0" spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.pilotosf1iterator.Controller.PilotoController">
    <Label text="Banco de dados dos pilotos" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    <Label text="Selecione a estrutura de dados desejada para a visualização das informações:" style="-fx-font-size: 15px; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10;">
        <Button style="-fx-background-color: #f9cec9;" minWidth="80.0" text="Pilha" onAction="#botaoPilha" />
        <Button style="-fx-background-color: #c9f9ce;" minWidth="80.0" text="Fila" onAction="#botaoFila" />
        <Button style="-fx-background-color: #f5f9c9;" minWidth="80.0" text="Árvore" onAction="#botaoArvore" />
        <Button style="-fx-background-color: #fbdbe8;" minWidth="80.0" text="Prioridade" onAction="#botaoPrioridade" />
        <Button style="-fx-background-color: #c9ddf9;" minWidth="80.0" text="Hash" onAction="#botaoHash" />
    </HBox>

    <TableView fx:id="tabelaPilotos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colMatricula" prefWidth="80.0" text="Matrícula" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colNome" prefWidth="130.0" text="Nome" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colPais" prefWidth="100.0" text="País" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colIdade" prefWidth="50.0" text="Idade" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colEquipe" prefWidth="100.0" text="Equipe" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colMotor" prefWidth="100.0" text="Motor" />
            <TableColumn style="-fx-background-color: #dedbfb;" fx:id="colPontos" prefWidth="50.0" text="Pontos" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>